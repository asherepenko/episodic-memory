{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/cli/episodic-memory.mjs\" sync --background",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
