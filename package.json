{
  "name": "episodic-memory",
  "version": "1.4.12",
  "description": "Semantic search for Claude Code and Codex conversations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "episodic-memory": "./cli/episodic-memory.mjs",
    "episodic-memory-index": "./cli/index-conversations.mjs",
    "episodic-memory-search": "./cli/search-conversations.mjs",
    "episodic-memory-mcp-server": "./cli/mcp-server.mjs"
  },
  "scripts": {
    "generate-version": "node scripts/generate-version.js",
    "prebuild": "npm run generate-version",
    "build": "tsc && npm run fix-cli && npm run bundle",
    "fix-cli": "node scripts/fix-cli-shebangs.mjs",
    "bundle": "esbuild src/mcp-server.ts --bundle --platform=node --format=esm --outfile=dist/mcp-server.js --external:fsevents --external:@anthropic-ai/claude-agent-sdk --external:sharp --external:onnxruntime-node --external:better-sqlite3 --external:@huggingface/transformers --external:sqlite-vec",
    "postinstall": "node scripts/postinstall.js",
    "pretest": "npm run generate-version",
    "test": "vitest run",
    "test:claude-e2e": "node scripts/claude-e2e.js",
    "test:codex-e2e": "node scripts/codex-e2e.js",
    "test:watch": "vitest"
  },
  "keywords": [
    "claude-code",
    "codex",
    "conversations",
    "search",
    "semantic-search",
    "embeddings"
  ],
  "author": {
    "name": "Andrew Sherepenko",
    "email": "andrew.sherepenko@gmail.com"
  },
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.159",
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "marked": "^18.0.4",
    "sqlite-vec": "^0.1.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/asherepenko/episodic-memory"
  },
  "homepage": "https://github.com/asherepenko/episodic-memory"
}
